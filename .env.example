# =============================================
# NIDO - ENVIRONMENT VARIABLES
# =============================================
# Copia este archivo como .env y configura los valores
# =============================================

# ENTORNO DE EJECUCIÓN
# =============================================
NODE_ENV=development
PORT=5000
HOST=0.0.0.0
BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
TIMEZONE=UTC

# BASE DE DATOS
# =============================================
MONGODB_URI=mongodb://localhost:27017/nido
DB_NAME=nido

# AUTENTICACIÓN Y SEGURIDAD
# =============================================
JWT_SECRET=tu_jwt_secret_super_seguro_minimo_32_caracteres
JWT_REFRESH_SECRET=tu_jwt_refresh_secret_super_seguro_minimo_32_caracteres
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d
BCRYPT_SALT_ROUNDS=12

COOKIE_SECRET=tu_cookie_secret_super_seguro_minimo_32_caracteres
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=lax

# CORREO ELECTRÓNICO
# =============================================
EMAIL_SERVICE=gmail
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=tu_password_de_aplicacion

# PAGOS - STRIPE
# =============================================
STRIPE_SECRET_KEY=sk_test_tu_clave_secreta_de_stripe
STRIPE_PUBLISHABLE_KEY=pk_test_tu_clave_publica_de_stripe
STRIPE_WEBHOOK_SECRET=whsec_tu_webhook_secret_de_stripe

# PAGOS - MERCADO PAGO
# =============================================
MERCADO_PAGO_ACCESS_TOKEN=TEST_tu_access_token_de_mercado_pago

# REDIS (OPCIONAL - PARA CACHÉ Y SESIONES)
# =============================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# CONFIGURACIÓN DE ARCHIVOS
# =============================================
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp

# CORS Y SEGURIDAD
# =============================================
CORS_ORIGINS=http://localhost:3000

# RATE LIMITING
# =============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CONFIGURACIÓN DE LA APLICACIÓN
# =============================================
LOG_LEVEL=info
ENABLE_SWAGGER=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PAYMENT_PROCESSING=true
ENABLE_GOOGLE_AUTH=true

# =============================================
# VARIABLES PARA EL FRONTEND (REACT)
# =============================================

# API CONFIGURATION
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_API_BASE_URL=http://localhost:3000/api

# GOOGLE MAPS
REACT_APP_MAPS_API_KEY=tu_api_key_de_google_maps

# =============================================
# VARIABLES PARA TESTING (OPCIONAL)
# =============================================
TEST_MONGODB_URI=mongodb://localhost:27017/nido_test

# =============================================
# VARIABLES PARA AWS (OPCIONAL - SI SE USA AWS)
# =============================================
# AWS_ACCESS_KEY_ID=tu_aws_access_key
# AWS_SECRET_ACCESS_KEY=tu_aws_secret_key
# AWS_SESSION_TOKEN=tu_aws_session_token
# AWS_REGION=us-east-1

# =============================================
# NOTAS IMPORTANTES:
# 1. Nunca commits el archivo .env real
# 2. Mantén las claves secretas seguras
# 3. Para producción, usa variables de entorno reales del servidor
# 4. Las variables con valor vacío son opcionales
# =============================================
